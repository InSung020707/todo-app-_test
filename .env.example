# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed.

# Supabase project URL (publishable — safe for the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (publishable) key — safe for the browser bundle.
# DO NOT put SUPABASE_SERVICE_ROLE_KEY here; this feature does not use it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
